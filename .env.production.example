# Clinic Workforce MVP — Production Environment Template
# Copy to .env.production and fill in ALL values

# ============================================
# Database
# ============================================
DB_USER=clinic
DB_PASSWORD=CHANGE-ME-USE-STRONG-PASSWORD

# ============================================
# Authentication
# ============================================
# MUST be a cryptographically random string (use: openssl rand -base64 32)
JWT_SECRET=CHANGE-ME-RUN-openssl-rand-base64-32
NEXTAUTH_SECRET=CHANGE-ME-RUN-openssl-rand-base64-32

# ============================================
# Application URL
# ============================================
NEXTAUTH_URL=https://your-domain.com

# ============================================
# Email (for password reset notifications)
# ============================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password-or-app-password
SMTP_FROM=noreply@your-domain.com

# ============================================
# Data Retention (PDPO compliance)
# ============================================
# Number of days to retain audit logs and operational data
# Minimum recommended: 365 (1 year) per HK Employment Ordinance
DATA_RETENTION_DAYS=365
