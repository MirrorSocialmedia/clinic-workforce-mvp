# Clinic Workforce MVP — Environment Variables Template
# Copy this file to .env.production and fill in the values

# Database
DB_USER=clinic
DB_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://clinic:change_me_to_a_strong_password@db:5432/clinic_mvp

# JWT (MUST be >= 32 chars in production!)
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars_long

# NextAuth
NEXTAUTH_SECRET=change_me_to_a_random_string
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Deployment
APP_PORT=3000

# Email (optional — for password reset)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-email@domain.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@your-domain.com

# Data Retention
DATA_RETENTION_DAYS=365
