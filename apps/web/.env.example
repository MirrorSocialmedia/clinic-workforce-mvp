# Database
# PostgreSQL (primary)
DATABASE_URL="postgresql://clinic:your-password@localhost:5432/clinic_mvp"

# SQLite for local development (fallback)
# DATABASE_URL="file:./dev.db"

# JWT Secret (MUST be >= 32 chars in production!)
JWT_SECRET="your-secure-random-secret-at-least-32-chars-long-here"

# Session / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# Email (for password reset)
# SMTP_HOST="smtp.your-provider.com"
# SMTP_PORT=587
# SMTP_USER="your-email@domain.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@your-domain.com"

# Data Retention (days) — for automated cleanup
# Default: 365 (1 year)
# DATA_RETENTION_DAYS=365
