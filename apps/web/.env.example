# Database
# SQLite for development
DATABASE_URL="file:./dev.db"

# PostgreSQL for production (Docker)
# DATABASE_URL="postgresql://clinic:your-password@localhost:5432/clinic_mvp"

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET="clinic-mvp-dev-secret-change-in-production-2024"

# Session / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="clinic-mvp-nextauth-secret-change-in-production"

# Email (for password reset)
# SMTP_HOST="smtp.your-provider.com"
# SMTP_PORT=587
# SMTP_USER="your-email@domain.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@your-domain.com"

# Data Retention (days) — for automated cleanup
# Default: 365 (1 year)
# DATA_RETENTION_DAYS=365
