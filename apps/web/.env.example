# Database
# SQLite for local development
DATABASE_URL="file:./dev.db"

# PostgreSQL for production (Docker)
# DATABASE_URL="postgresql://clinic:your-password@localhost:5432/clinic_mvp"

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET="your-secure-random-secret-at-least-32-chars-long-here"

# Session / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# Email (for password reset)
# SMTP_HOST="smtp.your-provider.com"
# SMTP_PORT=587
# SMTP_USER="your-email@domain.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@your-domain.com"

# Data Retention (days) — for automated cleanup
# Default: 365 (1 year)
# DATA_RETENTION_DAYS=365

# Face Verification
FACE_SERVICE_URL=http://face:8000
FACE_THRESHOLD=0.45
FACE_MODE=shadow
NEXT_PUBLIC_FACE_MODE=shadow
