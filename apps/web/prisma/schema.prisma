// Clinic Workforce MVP — Prisma Schema
// Supports PostgreSQL (production) and SQLite (dev fallback)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Change to "postgresql" for production
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  OWNER
  MANAGER
  ACCOUNTANT
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  PROBATION
}

enum PayType {
  MONTHLY
  DAILY
  HOURLY
  SPLIT
}

enum ShiftStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PunchType {
  CLOCK_IN
  CLOCK_OUT
}

enum PunchSource {
  QR_DYNAMIC
  QR_STATIC
  MANUAL_CORRECTION
  SYSTEM
}

// Shift change request types
enum ChangeType {
  SWAP
  COVER
  REPORT
}

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// Clinic entity
model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String?
  config    String?  // JSON string for SQLite compat
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     UserClinic[]
  employees EmployeeClinic[]
  shifts    Shift[]
  punches   PunchRecord[]
}

// User entity — system login account
model User {
  id        String       @id @default(cuid())
  name      String
  phone     String       @unique
  email     String?
  password  String       // bcrypt hash
  role      UserRole     @default(EMPLOYEE)
  status    UserStatus   @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  clinics   UserClinic[]
  employee  Employee?
  auditLogs AuditLog[]   @relation("ActorLogs")

  @@index([role])
  @@index([status])
  @@index([phone])
}

// Join table: User ↔ Clinic (access scope)
model UserClinic {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, clinicId])
  @@index([userId])
  @@index([clinicId])
}

// Employee entity
model Employee {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id])
  clinics   EmployeeClinic[]
  payRules  PayRule[]
  shifts    Shift[]
  punches   PunchRecord[]
  changeRequestsFrom ShiftChangeRequest[] @relation("ChangeFrom")
  changeRequestsTo   ShiftChangeRequest[] @relation("ChangeTo")
  changeRequestsAsApprover ShiftChangeRequest[] @relation("ChangeApprover")
  joinDate  DateTime
  leaveDate DateTime?
  status    EmployeeStatus   @default(ACTIVE)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// Join table: Employee ↔ Clinic
model EmployeeClinic {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(true)
  joinedAt   DateTime @default(now())

  @@unique([employeeId, clinicId])
  @@index([employeeId])
  @@index([clinicId])
}

// Pay rule
model PayRule {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payType       PayType
  baseAmount    Float?
  configJson    String?  // JSON string for SQLite compat
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean  @default(true)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Shift template — reusable shift definitions
model ShiftTemplate {
  id          String   @id @default(cuid())
  name        String
  startHour   Int      // hour of day start (0-23)
  startMinute Int      // minute of day start (0-59)
  endHour     Int      // hour of day end (0-23)
  endMinute   Int      // minute of day end (0-59)
  isNightShift Boolean @default(false) // true if end crosses midnight
  isDefault   Boolean  @default(false) // system default template
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shifts      Shift[]

  @@index([isDefault])
}

// Shift — links employee to a date/time at a clinic
model Shift {
  id          String      @id @default(cuid())
  employeeId  String
  clinicId    String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  role        String?
  status      ShiftStatus @default(CONFIRMED)
  templateId  String?
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id])
  clinic      Clinic      @relation(fields: [clinicId], references: [id])
  template    ShiftTemplate? @relation(fields: [templateId], references: [id])
  changeRequests ShiftChangeRequest[]

  @@index([employeeId, date])
  @@index([clinicId, date])
  @@index([status])
}

// Punch record — APPEND ONLY
model PunchRecord {
  id          String      @id @default(cuid())
  employeeId  String
  clinicId    String
  punchTime   DateTime
  punchType   PunchType
  source      PunchSource
  tokenValid  Boolean?
  deviceInfo  String?
  notes       String?
  createdAt   DateTime    @default(now())

  employee    Employee    @relation(fields: [employeeId], references: [id])
  clinic      Clinic      @relation(fields: [clinicId], references: [id])

  @@index([employeeId, punchTime])
}

// Audit log — APPEND ONLY
model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  action      String   // CREATE, UPDATE, DELETE, CORRECT, APPROVE, REJECT
  entity      String
  entityId    String
  clinicId    String?
  beforeJson  String?  // JSON string for SQLite compat
  afterJson   String?  // JSON string for SQLite compat
  notes       String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor       User     @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@index([clinicId, createdAt])
}

// Shift change request — swap/cover/report
model ShiftChangeRequest {
  id             String       @id @default(cuid())
  shiftId        String
  shift          Shift        @relation(fields: [shiftId], references: [id])
  fromEmployeeId String
  fromEmployee   Employee     @relation("ChangeFrom", fields: [fromEmployeeId], references: [id])
  toEmployeeId   String?
  toEmployee     Employee?    @relation("ChangeTo", fields: [toEmployeeId], references: [id])
  type           ChangeType
  reason         String?
  status         ChangeStatus @default(PENDING)
  approverId     String?
  approver       Employee?    @relation("ChangeApprover", fields: [approverId], references: [id])
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([fromEmployeeId, status])
  @@index([toEmployeeId, status])
  @@index([status])
}
