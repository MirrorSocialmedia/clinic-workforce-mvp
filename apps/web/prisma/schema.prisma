// Clinic Workforce MVP — Prisma Schema
// Supports PostgreSQL (production) and SQLite (dev fallback)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  OWNER
  MANAGER
  ACCOUNTANT
  EMPLOYEE
  KIOSK
}

enum UserStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  PROBATION
}

enum PayType {
  MONTHLY
  DAILY
  HOURLY
  SPLIT
}

enum ShiftStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PunchType {
  CLOCK_IN
  CLOCK_OUT
}

enum PunchSource {
  QR_DYNAMIC
  QR_STATIC
  MANUAL_CORRECTION
  SYSTEM
}

// Shift change request types
enum ChangeType {
  SWAP
  COVER
  REPORT
}

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// Punch correction status
enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

// Leave request status
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// Company entity — parent of clinics
model Company {
  id        String   @id @default(cuid())
  name      String
  logoData  String?  // data URL (image/png;base64,...)
  createdAt DateTime @default(now())

  clinics   Clinic[]
}

// Clinic entity
model Clinic {
  id        String   @id @default(cuid())
  name      String
  shortName String?  // 店鋪簡稱（1-2字：旺/仁/銅/荃/元/沙）
  address   String?
  config    String?  // JSON string for SQLite compat
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  users     UserClinic[]
  employees EmployeeClinic[]
  shifts    Shift[]
  punches   PunchRecord[]
  qrTokens  QRToken[]
  dailyHashes DailyHash[]
  payrollRuns PayrollRun[]
  homeEmployees Employee[] @relation("HomeClinic")
}

// User entity — system login account
model User {
  id        String       @id @default(cuid())
  name      String
  phone     String       @unique
  email     String?
  password  String       // bcrypt hash
  role      UserRole     @default(EMPLOYEE)
  status    UserStatus   @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  clinics   UserClinic[]
  employee  Employee?
  auditLogs       AuditLog[]   @relation("ActorLogs")
  resetToken      String?
  resetTokenExpiry DateTime?
  permissionsJson String? // JSON: { "grant": [...], "deny": [...] }
  tokenVersion   Int      @default(0)
  ipAllowlist    String?  // comma-separated IPs or prefixes (KIOSK only)

  @@index([role])
  @@index([status])
  @@index([phone])
}

// Join table: User ↔ Clinic (access scope)
model UserClinic {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, clinicId])
  @@index([userId])
  @@index([clinicId])
}

// Employee entity
model Employee {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id])
  clinics   EmployeeClinic[]
  homeClinicId String?
  homeClinic Clinic? @relation("HomeClinic", fields: [homeClinicId], references: [id])
  payRules  PayRule[]
  shifts           Shift[]
  punches          PunchRecord[]
  punchCorrections PunchCorrection[]
  changeRequestsFrom ShiftChangeRequest[] @relation("ChangeFrom")
  changeRequestsTo   ShiftChangeRequest[] @relation("ChangeTo")
  changeRequestsAsApprover ShiftChangeRequest[] @relation("ChangeApprover")
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]
  timeBankRecords TimeBank[]
  timeBankEntries TimeBankEntry[]
  payrollItems  PayrollItem[]
  faceTemplates FaceTemplate[]
  joinDate  DateTime
  leaveDate DateTime?
  status    EmployeeStatus   @default(ACTIVE)
  payConfidential Boolean @default(false) // 薪資保密 — 非 OWNER 的計糧 API 遮蔽金額
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// Join table: Employee ↔ Clinic
model EmployeeClinic {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(true)
  joinedAt   DateTime @default(now())

  @@unique([employeeId, clinicId])
  @@index([employeeId])
  @@index([clinicId])
}

// Pay rule
model PayRule {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payType       PayType
  baseAmount    Float?
  configJson    String?  // JSON string for SQLite compat
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean  @default(true)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Shift template — reusable shift definitions
model ShiftTemplate {
  id          String   @id @default(cuid())
  name        String
  startHour   Int      // hour of day start (0-23)
  startMinute Int      // minute of day start (0-59)
  endHour     Int      // hour of day end (0-23)
  endMinute   Int      // minute of day end (0-59)
  isNightShift Boolean @default(false) // true if end crosses midnight
  shortName     String?  // 總覽顯示用簡稱（如「早」「夜」「A」），null 用 name
  isDefault   Boolean  @default(false) // system default template
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shifts      Shift[]

  @@index([isDefault])
}

// Shift — links employee to a date/time at a clinic
model Shift {
  id          String      @id @default(cuid())
  employeeId  String
  clinicId    String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  role        String?
  status      ShiftStatus @default(CONFIRMED)
  templateId  String?
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id])
  clinic      Clinic      @relation(fields: [clinicId], references: [id])
  template    ShiftTemplate? @relation(fields: [templateId], references: [id])
  changeRequests ShiftChangeRequest[]

  @@index([employeeId, date])
  @@index([clinicId, date])
  @@index([status])
}

// Punch record — APPEND ONLY (no UPDATE/DELETE API)
model PunchRecord {
  id          String      @id @default(cuid())
  employeeId  String
  clinicId    String
  punchTime   DateTime
  punchType   PunchType
  source      PunchSource
  tokenValid  Boolean?
  deviceInfo  String?
  notes       String?
  faceStatus    String? // PASS | FAIL | NOT_ENROLLED | SKIPPED
  faceScore     Float?
  faceLiveness  Float?
  faceFramePath String? // 只有 FAIL 有值；30 天清
  faceReviewedAt DateTime?
  faceReviewedBy String?
  faceReason     String? // 異常原因代碼
  createdAt   DateTime    @default(now())

  employee    Employee    @relation(fields: [employeeId], references: [id])
  clinic      Clinic      @relation(fields: [clinicId], references: [id])

  corrections PunchCorrection[] // corrections referencing this record
  void        PunchVoid?        // void record (null = active)

  @@index([employeeId, punchTime])
}

// Punch void — cancels a punch record without deleting it (append-only)
model PunchVoid {
  id            String      @id @default(cuid())
  punchRecordId String      @unique
  punchRecord   PunchRecord @relation(fields: [punchRecordId], references: [id])
  voidedBy      String      // userId who voided
  reason        String      // void reason (required)
  createdAt     DateTime    @default(now())
}

// Punch correction — overlay on top of punch records (never modifies originals)
model PunchCorrection {
  id             String           @id @default(cuid())
  punchRecordId  String?          // null = no original record exists
  employeeId     String
  clinicId       String
  correctedTime  DateTime
  punchType      PunchType
  reason         String?
  requestedBy    String           // userId of requester
  approvedBy     String?          // userId of approver
  status         CorrectionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // References
  punchRecord    PunchRecord?     @relation(fields: [punchRecordId], references: [id])
  employee       Employee         @relation(fields: [employeeId], references: [id])

  @@index([employeeId, createdAt])
  @@index([status])
}

// QR token — short-lived dynamic tokens for punch verification
model QRToken {
  id        String   @id @default(cuid())
  clinicId  String
  token     String   @unique
  shortCode String?  // 8字元短碼，QR碼只顯示它（降密度）
  issuedAt  DateTime
  expiresAt DateTime
  used      Boolean  @default(false)
  usedBy    String?  // employeeId
  usedAt    DateTime?
  createdAt DateTime @default(now())

  clinic    Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  usages    QRTokenUsage[] // ★ 每人對每碼一次的 usage 記錄

  @@index([clinicId, expiresAt])
  @@index([token])
  @@index([shortCode])
}

// QR token usage — tracks which employee used which token (per-person-per-token)
model QRTokenUsage {
  id         String   @id @default(cuid())
  tokenId    String
  employeeId String
  usedAt     DateTime @default(now())
  token      QRToken  @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([tokenId, employeeId]) // ★ 每人對每碼一次——資料庫層面原子保證
}

// Daily hash — SHA-256 fingerprint of all punch records for a clinic on a given date
model DailyHash {
  id          String   @id @default(cuid())
  clinicId    String
  date        DateTime // YYYY-01-01 format (date only)
  hash        String   // SHA-256 hex string
  recordCount Int
  createdAt   DateTime @default(now())

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, date])
  @@index([clinicId, date])
}

// Audit log — APPEND ONLY
model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  action      String   // CREATE, UPDATE, DELETE, CORRECT, APPROVE, REJECT
  entity      String
  entityId    String
  clinicId    String?
  beforeJson  String?  // JSON string for SQLite compat
  afterJson   String?  // JSON string for SQLite compat
  notes       String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor       User     @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@index([clinicId, createdAt])
}

// Shift change request — swap/cover/report
model ShiftChangeRequest {
  id             String       @id @default(cuid())
  shiftId        String
  shift          Shift        @relation(fields: [shiftId], references: [id])
  fromEmployeeId String
  fromEmployee   Employee     @relation("ChangeFrom", fields: [fromEmployeeId], references: [id])
  toEmployeeId   String?
  toEmployee     Employee?    @relation("ChangeTo", fields: [toEmployeeId], references: [id])
  type           ChangeType
  reason         String?
  status         ChangeStatus @default(PENDING)
  approverId     String?
  approver       Employee?    @relation("ChangeApprover", fields: [approverId], references: [id])
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([fromEmployeeId, status])
  @@index([toEmployeeId, status])
  @@index([status])
}

// Leave type — 年假/病假/無薪假 etc.
model LeaveType {
  id           String   @id @default(cuid())
  clinicId     String?  // null = global type
  name         String   // 年假/病假/無薪假
  systemKey    String?  @unique // 'REST_DAY' | 'ANNUAL_LEAVE' | 'OT_LEAVE' | null
  isPaid       Boolean  @default(true)
  annualQuota  Float?   // 年度額度（天）
  color        String?  // UI 顏色標記
  quantity     Int?     // 預設額度（nullable = 無限制）
  isActive     Boolean  @default(true)
  cancelsBonus Boolean  @default(false) // 請此假當月取消勤工獎
  createdAt    DateTime @default(now())

  requests     LeaveRequest[]
  balances     LeaveBalance[]
}

// Leave request — employee applies for leave
model LeaveRequest {
  id          String         @id @default(cuid())
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id])
  leaveTypeId String
  leaveType   LeaveType      @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String?
  status      LeaveStatus    @default(PENDING)
  approverId  String?
  approvedAt  DateTime?
  isPlanned   Boolean        @default(true) // false=臨時/當天假 → 影響勤工
  clinicId    String?        // 新增：在哪個店排的假（排班跨店過濾）
  createdAt   DateTime       @default(now())

  @@index([employeeId, status])
  @@index([leaveTypeId])
  @@index([clinicId])
}

// Leave balance — annual quota tracking per employee
model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  year        Int       // 年份
  entitled    Float     // 總額
  used        Float     @default(0)
  remaining   Float     @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId, year])
}

// Notification — in-app notifications
model Notification {
  id             String   @id @default(cuid())
  employeeId     String
  type           String   // LEAVE_APPROVED, LEAVE_REJECTED, SHIFT_CHANGED, CORRECTION_APPROVED
  content        String
  relatedEntity  String?  // LeaveRequest, Shift, PunchCorrection
  relatedId      String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([employeeId, isRead, createdAt])
}

// HK Public Holiday
model HKPublicHoliday {
  id    String   @id @default(cuid())
  date  DateTime @unique
  name  String
}

// ============================================================
// Phase 6: Payroll
// ============================================================

enum RunStatus {
  DRAFT
  FINALIZED
  EXPORTED
}

model PayrollRun {
  id           String       @id @default(cuid())
  clinicId     String?      // null = all clinics (cross-clinic)
  clinic       Clinic?      @relation(fields: [clinicId], references: [id])
  periodMonth  DateTime     // YYYY-MM-01 format
  status       RunStatus    @default(DRAFT)
  generatedAt  DateTime     @default(now())
  notes        String?
  items        PayrollItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([clinicId, periodMonth])
  @@index([periodMonth])
}

model PayrollItem {
  id           String      @id @default(cuid())
  runId        String
  run          PayrollRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id])
  workedHours  Float       @default(0)
  otHours      Float       @default(0)
  leaveDays    Float       @default(0)
  absentDays   Float       @default(0)
  basePay      Float       @default(0)
  otPay        Float       @default(0)
  splitPay     Float?      // 拆帳（醫生）
  deduction    Float       @default(0)
  storeBonus   Float       @default(0) // 店舖營業額獎金（手動輸入，月薪限定）
  totalPayable Float       @default(0)
  detailJson   String?     // JSON string for SQLite compat
  createdAt    DateTime    @default(now())

  @@unique([runId, employeeId])
  @@index([employeeId, createdAt])
}

// ============================================================
// Consultation Revenue — actual monthly revenue per doctor per clinic
// FIX #8: Replace consultation_target (goal) with actual input
// ============================================================

model ConsultationRevenue {
  id          String   @id @default(cuid())
  employeeId  String
  clinicId    String
  month       DateTime // YYYY-MM-01 format
  amount      Float
  source      String?  // Source note (e.g., "billing system export")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, clinicId, month])
  @@index([employeeId, month])
  @@index([clinicId, month])
}

// ============================================================
// Time Bank — OT / late tracking per employee per month
// ============================================================

model TimeBank {
  id                String   @id @default(cuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodMonth       DateTime // YYYY-MM-01
  otMinutes         Int      @default(0)
  lateMinutes       Int      @default(0)
  earlyLeaveMinutes Int      @default(0)
  makeupMinutes     Int      @default(0)
  balance           Int      @default(0) // ot - late
  carriedFrom       Int      @default(0) // 上月結轉
  monthEndNote      String?  // 月底結算備註
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([employeeId, periodMonth])
  @@index([employeeId, periodMonth])
}

// Time Bank Entry — individual line items
model TimeBankEntry {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  type       String   // 'OT' | 'LATE' | 'EARLY' | 'MAKEUP' | 'LEAVE_CONVERT' | 'LEAVE_SWAP_BACK'
  minutes    Int      // 正=進帳(OT/換回)，負=出帳(補鐘/換假)
  note       String?
  createdBy  String?  // 補鐘/換假記誰做的
  targetType String?  // 'LATE' | 'EARLY_LEAVE' | 'ABSENT'（MAKEUP 類型用，按類型標記避免連坐）
  createdAt  DateTime @default(now())

  @@index([employeeId, date])
}

// ============================================================
// Face Verification — shadow mode, never blocks punch
// ============================================================

model FaceTemplate {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  embedding       String   // Float32[512] 的 JSON 字串
  active          Boolean  @default(true)
  enrolledAt      DateTime @default(now())
  enrolledBy      String
  consentAt       DateTime
  consentVersion  String
  approvedAt      DateTime?
  approvedBy      String?      // userId of approver
  refFrameId      String?      // face-service 上參考照的檔名 key
  @@index([employeeId, active])
}

model FaceEnrollCode {
  id          String   @id @default(cuid())
  employeeId  String
  code        String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdBy   String
}
